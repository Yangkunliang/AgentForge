# Database
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agentforge
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agentforge

# Database Connection Pool
# pool_size: 连接池保持的空闲连接数，建议设置为 CPU 核心数的 1-2 倍
# max_overflow: 超出 pool_size 后允许的最大额外连接数
# pool_timeout: 获取连接的等待超时时间（秒）
# pool_recycle: 连接回收间隔（秒），建议小于数据库的 idle_in_transaction_session_timeout
#               PostgreSQL 默认 10 分钟，这里设置 30 分钟较为安全
# pool_pre_ping: 获取连接前是否检查可用性，生产环境建议开启
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute

# LLM（OpenAI-compatible 接口，如百炼 / Azure / 本地部署）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-api-key
LLM_MODEL=openai/qwen-plus
VL_MODEL=openai/qwen-vl-max
T2I_MODEL=openai/wanx2.1-t2i-turbo

# Skill 市场
# ClawhHub API 地址，配置后可在技能市场浏览 ClawhHub 上的 Skill
# CLAWHUB_API_BASE=https://api.clawhub.ai
# GitHub API Token，用于访问 GitHub API 获取 Skill 列表（可选，提高请求限制）
# GITHUB_API_TOKEN=your-github-token
